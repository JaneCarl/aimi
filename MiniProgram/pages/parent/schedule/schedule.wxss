.schedule-page {
  padding-bottom: 120rpx;
}

/* 日历 */
.calendar-card {
  margin: 24rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;

  .month-btn {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    color: #999;
  }

  .current-month {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 16rpx;

  .weekday {
    flex: 1;
    text-align: center;
    font-size: 24rpx;
    color: #999;
  }
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.28%;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-bottom: 8rpx;

  .day-number {
    font-size: 28rpx;
    color: #333;
  }

  .day-indicator {
    font-size: 12rpx;
    margin-top: 4rpx;
  }

  &.upcoming .day-indicator {
    color: #FF9800;
  }

  &.normal .day-indicator {
    color: #4CAF50;
  }

  &.late .day-indicator {
    color: #FFC107;
  }

  &.leave .day-indicator {
    color: #2196F3;
  }

  &.completed .day-indicator {
    color: #999;
  }
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 20rpx;

  .legend-item {
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #666;

    .legend-dot {
      width: 16rpx;
      height: 16rpx;
      border-radius: 50%;
      margin-right: 8rpx;

      &.upcoming {
        background: #FF9800;
      }

      &.normal {
        background: #4CAF50;
      }

      &.late {
        background: #FFC107;
      }

      &.leave {
        background: #2196F3;
      }

      &.completed {
        background: #999;
      }
    }
  }
}

/* 课程列表 */
.schedule-list {
  padding: 0 24rpx;
}

.schedule-item {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.schedule-info {
  flex: 1;
  margin-bottom: 16rpx;

  .schedule-time {
    display: flex;
    flex-direction: column;
    margin-bottom: 12rpx;

    .date {
      font-size: 24rpx;
      color: #999;
      margin-bottom: 4rpx;
    }

    .time {
      font-size: 32rpx;
      font-weight: 600;
      color: #FF6B6B;
    }
  }

  .schedule-class {
    .class-name {
      display: block;
      font-size: 28rpx;
      color: #333;
      margin-bottom: 4rpx;
    }

    .coach-name {
      font-size: 24rpx;
      color: #999;
    }
  }
}

.schedule-status {
  margin-bottom: 16rpx;
}

.leave-btn {
  background: #FF6B6B;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
