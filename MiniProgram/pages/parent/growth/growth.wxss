.growth-page {
  padding-bottom: 120rpx;
}

.growth-timeline {
  padding: 0 24rpx;
}

.timeline-item {
  margin-bottom: 24rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;

  .timeline-date {
    font-size: 24rpx;
    color: #999;
  }

  .timeline-coach {
    font-size: 24rpx;
    color: #FF6B6B;
  }
}

.timeline-content {
  margin-bottom: 16rpx;

  .timeline-comment {
    font-size: 28rpx;
    color: #333;
    line-height: 1.6;
  }
}

.timeline-media {
  .media-image {
    width: 100%;
    height: 400rpx;
    border-radius: 12rpx;
  }
}

.empty {
  text-align: center;
   padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
