.leave-page {
  padding-bottom: 120rpx;
}

/* 请假表单 */
.leave-form {
  margin: 24rpx;
}

.form-header {
  margin-bottom: 24rpx;

  .form-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.class-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;

  .info-label {
    font-size: 28rpx;
    color: #666;
    width: 120rpx;
  }

  .info-value {
    font-size: 28rpx;
    color: #333;
  }
}

.form-item {
  margin-top: 24rpx;

  .form-label {
    display: block;
    font-size: 28rpx;
    color: #666;
    margin-bottom: 12rpx;
  }

  .form-textarea {
    width: 100%;
    min-height: 160rpx;
    padding: 16rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    font-size: 28rpx;
    box-sizing: border-box;
  }
}

.submit-btn {
  margin-top: 32rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 20rpx;
}

/* 请假记录 */
.leave-records {
  padding: 0 24rpx;
}

.section-header {
  margin-bottom: 20rpx;

  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.record-item {
  margin-bottom: 24rpx;

  .record-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12rpx;

    .record-class {
      font-size: 28rpx;
      color: #333;
      font-weight: 600;
    }

    .record-date {
      font-size: 24rpx;
      color: #999;
    }
  }

  .record-reason {
    margin-bottom: 12rpx;

    .reason-label {
      font-size: 24rpx;
      color: #666;
    }

    .reason-text {
      font-size: 24rpx;
      color: #333;
    }
  }

  .record-status {
    display: flex;
    justify-content: flex-end;
  }
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
