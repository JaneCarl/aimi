.detail-page {
  padding-bottom: 200rpx;
}

/* 课程信息 */
.class-info {
  margin: 24rpx;
}

.info-header {
  margin-bottom: 16rpx;

  .class-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.info-content {
  .info-item {
    display: flex;
    font-size: 28rpx;
    margin-bottom: 8rpx;

    .label {
      color: #666;
      width: 100rpx;
    }

    .value {
      color: #333;
    }
  }
}

/* 学员列表 */
.students-list {
  padding: 0 24rpx;
}

.section-header {
  margin-bottom: 20rpx;

  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.student-item {
  margin-bottom: 24rpx;
}

.student-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;

  .student-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 16rpx;
  }

  .student-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }
}

.attendance-form {
  .form-row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 20rpx;

    .form-label {
      font-size: 28rpx;
      color: #666;
      width: 140rpx;
      padding-top: 8rpx;
    }

    .radio-group {
      flex: 1;
      display: flex;
      flex-wrap: wrap;
      gap: 24rpx;
    }

    .radio-item {
      display: flex;
      align-items: center;
      font-size: 28rpx;
      color: #333;

      radio {
        margin-right: 8rpx;
      }
    }

    .score-input,
    .points-input {
      flex: 1;
      height: 60rpx;
      padding: 0 16rpx;
      background: #f5f5f5;
      border-radius: 8rpx;
      font-size: 28rpx;
    }

    .comment-textarea {
      flex: 1;
      min-height: 120rpx;
      padding: 16rpx;
      background: #f5f5f5;
      border-radius: 8rpx;
      font-size: 28rpx;
    }

    .media-section {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 16rpx;
    }

    .upload-btn {
      background: #FF6B6B;
      color: #fff;
      border-radius: 8rpx;
      font-size: 24rpx;
      padding: 8rpx 16rpx;
    }

    .media-preview {
      width: 100rpx;
      height: 100rpx;
      border-radius: 8rpx;
      overflow: hidden;

      .preview-image {
        width: 100%;
        height: 100%;
      }

      .preview-video {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48rpx;
        background: #f5f5f5;
      }
    }
  }
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}
