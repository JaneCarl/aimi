<view class="students-page">
  <view class="students-list">
    <view
      class="student-item card"
      wx:for="{{students}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="navigateToDetail"
    >
      <view class="student-info">
        <image class="student-avatar" src="{{item.photo || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="student-details">
          <text class="student-name">{{item.name}}</text>
          <text class="student-age">{{item.birth_date}}</text>
        </view>
      </view>
      <text class="arrow">></text>
    </view>

    <view class="empty" wx:if="{{students.length === 0}}">
      <text>暂无学生</text>
    </view>
  </view>
</view>
