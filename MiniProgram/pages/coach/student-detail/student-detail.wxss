.student-detail-page {
  padding-bottom: 120rpx;
}

/* 学生信息 */
.student-info {
  margin: 24rpx;
}

.info-header {
  display: flex;
  align-items: center;

  .student-avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    margin-right: 24rpx;
  }

  .student-basic {
    flex: 1;

    .student-name {
      display: block;
      font-size: 36rpx;
      font-weight: 600;
      color: #333;
      margin-bottom: 12rpx;
    }

    .student-meta {
      font-size: 24rpx;
      color: #999;
      line-height: 1.6;
    }
  }
}

/* 最近课堂记录 */
.recent-records {
  padding: 0 24rpx;
}

.section-header {
  margin-bottom: 20rpx;

  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
}

.record-item {
  margin-bottom: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;

  .record-class {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }

  .record-date {
    font-size: 24rpx;
    color: #999;
  }
}

.record-body {
  .record-field {
    display: flex;
    margin-bottom: 8rpx;
    font-size: 26rpx;

    .field-label {
      color: #666;
      width: 100rpx;
    }

    .field-value {
      color: #333;
    }
  }
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
