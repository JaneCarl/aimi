<view class="class-page">
  <view class="class-list">
    <view
      class="class-item card"
      wx:for="{{classRecords}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="navigateToDetail"
    >
      <view class="class-info">
        <view class="class-time">
          <text class="time">{{item.start_time}} - {{item.end_time}}</text>
          <text class="date">{{item.class_date}}</text>
        </view>
        <view class="class-details">
          <text class="class-name">{{item.class_name}}</text>
          <text class="student-count">学员：{{item.attendance_count || 0}} 人</text>
        </view>
      </view>
      <view class="class-status">
        <text class="tag {{getStatusClass(item.status)}}">{{getStatusText(item.status)}}</text>
      </view>
    </view>

    <view class="empty" wx:if="{{classRecords.length === 0}}">
      <text>今日暂无课程安排</text>
    </view>
  </view>
</view>
