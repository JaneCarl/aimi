.class-page {
  padding-bottom: 120rpx;
}

.class-list {
  padding: 0 24rpx;
}

.class-item {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.class-info {
  flex: 1;
  margin-bottom: 16rpx;

  .class-time {
    display: flex;
    flex-direction: column;
    margin-bottom: 12rpx;

    .time {
      font-size: 36rpx;
      font-weight: 600;
      color: #FF6B6B;
      margin-bottom: 4rpx;
    }

    .date {
      font-size: 24rpx;
      color: #999;
    }
  }

  .class-details {
    .class-name {
      display: block;
      font-size: 28rpx;
      color: #333;
      margin-bottom: 8rpx;
    }

    .student-count {
      font-size: 24rpx;
      color: #999;
    }
  }
}

.class-status {
  display: flex;
  justify-content: flex-end;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
